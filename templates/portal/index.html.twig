{% extends 'base.html.twig' %}

{% block title %}Event Portal{% endblock %}

{% block body %}
    <h1>Citizen Portal</h1>
   <div style="display: flex; justify-content: flex-end; gap: 20px; margin-bottom: 25px;">

        <a class="nav-link"
        href="{{ path('new_appointment') }}"
        style="border:1px solid #000000; padding: 8px 15px;">
            Create a new Appointment
        </a>

        <a class="nav-link"
        href="{{ path('appointments_list') }}"
        style="border:1px solid #000000; padding: 8px 15px;">
            Show all Appointments
        </a>

    </div>
    {% for event in events %}
        <div style="border:1px solid #ccc; padding:10px; margin-bottom:10px;">
            <h2>{{ event.name }}</h2>
            <p><strong>Date:</strong> {{ event.startsAt|date('Y-m-d H:i') }}</p>
            <p><strong>Location:</strong> {{ event.location }}</p>
            <p>{{ event.description }}</p>

            <h4>Appointments:</h4>
            <ul>
                {% for appointment in event.appointments %}
                    <li>
                        {{ appointment.title }} 
                        ({{ appointment.status }})
                    </li>
                    <ul>
                        {% for notification in appointment.notifications %}
                            <li>{{ notification.message }}</li>
                        {% endfor %}
                    </ul>
                {% endfor %}
            </ul>
        </div>
    {% else %}
        <p>No events available.</p>
    {% endfor %}
{% endblock %}
